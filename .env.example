# Application
APP_NAME=barekat-cell-therapy
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://barekat:barekat@localhost:5432/barekat_cell_therapy

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Object Storage (genomic profiles, CAR designs, production protocols)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=barekat
S3_SECRET_KEY=barekatsecret
S3_BUCKET=barekat-cell-therapy
S3_REGION=us-east-1

# Pipeline
PIPELINE_MODE=simulated
PIPELINE_WORK_DIR=/data/processed

# CAR Design
DEFAULT_CAR_VERSION=CARv3
SUPPORTED_TARGETS=CD19,CD20,BCMA,HER2,EGFR,PD-L1,MUC1,CEA
MIN_ANTIGEN_EXPRESSION=10.0

# Simulation
SIMULATION_HORIZON_DAYS=90
CRS_RISK_THRESHOLD=0.7
NEUROTOXICITY_RISK_THRESHOLD=0.3

# Privacy & Compliance
PHI_ENCRYPTION_ENABLED=false
AUDIT_LOG_ENABLED=true

# Auth
SECRET_KEY=barekat-cell-therapy-dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=480
AUTH_REQUIRED=false

# ML Models
MODEL_PATH=data/models
RESPONSE_MODEL=response_predictor_v1.pkl

# Observability
METRICS_ENABLED=true
LOG_JSON=false
LOG_LEVEL=INFO
